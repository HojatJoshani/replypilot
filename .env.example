# ReplyPilot — Environment Variables
# این فایل را به .env کپی کنید و مقادیر واقعی را وارد کنید.

# پایگاه داده (SQLite برای دمو؛ برای تولید PostgreSQL)
DATABASE_URL=file:/home/z/my-project/db/custom.db

# NextAuth
NEXTAUTH_SECRET= # با `openssl rand -hex 32` تولید کنید
NEXTAUTH_URL=http://localhost:3000

# کلید رمزنگاری AES-256 برای توکن‌های اینستاگرام (32 بایت هگز = 64 کاراکتر)
# با `openssl rand -hex 32` تولید کنید
ENCRYPTION_KEY=

# اینستاگرام / اپ متا (در حالت دمو خالی بگذارید)
# وقتی INSTAGRAM_APP_ID خالی باشد، اپ در حالت دمو اجرا می‌شود.
INSTAGRAM_APP_ID=
INSTAGRAM_APP_SECRET=
INSTAGRAM_VERIFY_TOKEN= # یک رشته دلخواه
INSTAGRAM_GRAPH_API_VERSION=v21.0

# هوش مصنوعی
AI_ENABLED=true
DEMO_MODE=true
